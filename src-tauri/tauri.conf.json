{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "光核超级服务",
  "version": "2.0.0",
  "identifier": "com.paishu.agi",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "光核超级服务",
        "width": 930,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Codex 额度与使用仪表盘",
    "longDescription": "用于查看本机 Codex 额度、令牌使用和任务状态的跨平台桌面仪表盘。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
